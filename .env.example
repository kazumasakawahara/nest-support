# Neo4j 接続設定（障害福祉 support-db）
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password

# Neo4j 接続設定（生活困窮者自立支援 livelihood-support）
NEO4J_LIVELIHOOD_URI=bolt://localhost:7688
NEO4J_LIVELIHOOD_USERNAME=neo4j
NEO4J_LIVELIHOOD_PASSWORD=password

# Google AI API（セマンティック検索のEmbedding生成・スキャンPDF OCRに使用）
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# LINE Messaging API（SOS通知用）
LINE_CHANNEL_ACCESS_TOKEN=YOUR_ACCESS_TOKEN
LINE_GROUP_ID=YOUR_GROUP_ID

# CORS設定（SOS API用、カンマ区切りで複数指定可能）
# 未設定時は全オリジン許可（開発用）
# CORS_ORIGINS=https://example.com,https://app.example.com

# 仮名化スキーマ（マイグレーション後に true に設定）
PSEUDONYMIZATION_ENABLED=false
# 仮名化モード: "mask"（部分マスク●）, "pseudonym"（架空名に置換）
PSEUDONYMIZATION_MODE=mask
# 仮名化シード値（pseudonymモードで同じ入力→同じ出力を保証するキー）
PSEUDONYMIZATION_SEED=nest-support-demo
